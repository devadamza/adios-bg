<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#7c3aed"/>
      <stop offset="100%" stop-color="#06b6d4"/>
    </linearGradient>
    <linearGradient id="shine" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="rgba(255,255,255,0.2)"/>
      <stop offset="50%" stop-color="rgba(255,255,255,0)"/>
    </linearGradient>
  </defs>
  <!-- Background -->
  <rect width="512" height="512" rx="96" fill="url(#bg)"/>
  <rect width="512" height="512" rx="96" fill="url(#shine)"/>
  <!-- Eraser/Magic wand icon -->
  <g transform="translate(256, 256)" fill="none" stroke="white" stroke-width="18" stroke-linecap="round" stroke-linejoin="round">
    <!-- Image frame -->
    <rect x="-110" y="-110" width="220" height="220" rx="24" opacity="0.4"/>
    <!-- Checkered pattern (transparency) -->
    <rect x="-88" y="-88" width="44" height="44" fill="white" opacity="0.15" stroke="none"/>
    <rect x="0" y="-88" width="44" height="44" fill="white" opacity="0.15" stroke="none"/>
    <rect x="-44" y="-44" width="44" height="44" fill="white" opacity="0.15" stroke="none"/>
    <rect x="44" y="-44" width="44" height="44" fill="white" opacity="0.15" stroke="none"/>
    <rect x="-88" y="0" width="44" height="44" fill="white" opacity="0.15" stroke="none"/>
    <rect x="0" y="0" width="44" height="44" fill="white" opacity="0.15" stroke="none"/>
    <rect x="-44" y="44" width="44" height="44" fill="white" opacity="0.15" stroke="none"/>
    <rect x="44" y="44" width="44" height="44" fill="white" opacity="0.15" stroke="none"/>
    <!-- Magic wand -->
    <line x1="-20" y1="130" x2="130" y2="-20" stroke-width="22"/>
    <!-- Sparkles -->
    <circle cx="100" cy="-70" r="6" fill="white" stroke="none"/>
    <circle cx="130" cy="-40" r="4" fill="white" stroke="none"/>
    <circle cx="70" cy="-100" r="3" fill="white" stroke="none"/>
    <!-- Stars -->
    <path d="M120,-90 l4,-12 4,12 12,4 -12,4 -4,12 -4,-12 -12,-4z" fill="white" stroke="none"/>
  </g>
</svg>
